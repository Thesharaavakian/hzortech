# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text file types to use LF
*.py     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.txt    text eol=lf
*.gitignore text eol=lf

# Binary files should be treated as binary (no conversion)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.exe    binary
*.tar    binary
*.gz     binary

# Docker / config files
Dockerfile text eol=lf
docker-compose*.yml text eol=lf