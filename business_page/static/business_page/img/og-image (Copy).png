<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" fill="none">
  <!-- Background -->
  <rect width="1200" height="630" fill="#0D0D0D"/>
  <!-- Subtle grid pattern -->
  <defs>
    <pattern id="grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(230,33,39,0.04)" stroke-width="1"/>
    </pattern>
  </defs>
  <rect width="1200" height="630" fill="url(#grid)"/>

  <!-- Left ember accent bar -->
  <rect x="80" y="80" width="3" height="470" fill="#E62127" opacity="0.6"/>

  <!-- HZ mark — large -->
  <g transform="translate(110, 160)">
    <!-- H -->
    <rect x="0" y="0" width="18" height="110" fill="#F0F0F0"/>
    <rect x="0" y="46" width="54" height="18" fill="#F0F0F0"/>
    <rect x="36" y="0" width="18" height="110" fill="#F0F0F0"/>
    <!-- Z -->
    <rect x="72" y="0" width="80" height="18" fill="#E62127"/>
    <line x1="152" y1="18" x2="72" y2="92" stroke="#E62127" stroke-width="14" stroke-linecap="square"/>
    <rect x="72" y="92" width="80" height="18" fill="#E62127"/>
  </g>

  <!-- HZORTECH wordmark -->
  <text x="110" y="330" font-family="'Inter Tight', Inter, system-ui, sans-serif" font-weight="900" font-size="72" letter-spacing="-2" fill="#F0F0F0">HZORTECH</text>

  <!-- Tagline -->
  <text x="112" y="390" font-family="'JetBrains Mono', 'Courier New', monospace" font-weight="400" font-size="22" letter-spacing="2" fill="#4A4E57" text-transform="uppercase">CLOUD · DEVOPS · SECURITY · AUTOMATION</text>

  <!-- Location badge -->
  <rect x="110" y="440" width="260" height="42" rx="6" fill="rgba(230,33,39,0.1)" stroke="rgba(230,33,39,0.25)" stroke-width="1"/>
  <text x="240" y="467" font-family="'JetBrains Mono', monospace" font-size="16" letter-spacing="3" fill="#E62127" text-anchor="middle">YEREVAN, ARMENIA</text>

  <!-- URL -->
  <text x="1120" y="570" font-family="'JetBrains Mono', monospace" font-size="18" letter-spacing="1" fill="#4A4E57" text-anchor="end">hzortech.com</text>

  <!-- Right side decorative circuit lines -->
  <g opacity="0.12" stroke="#E62127" stroke-width="1.5">
    <line x1="820" y1="80" x2="820" y2="550"/>
    <line x1="820" y1="200" x2="980" y2="200"/>
    <circle cx="980" cy="200" r="4" fill="#E62127" stroke="none"/>
    <line x1="980" y1="200" x2="980" y2="350"/>
    <line x1="980" y1="350" x2="1100" y2="350"/>
    <circle cx="1100" cy="350" r="4" fill="#E62127" stroke="none"/>
    <line x1="820" y1="420" x2="900" y2="420"/>
    <circle cx="900" cy="420" r="3" fill="#E62127" stroke="none"/>
    <line x1="900" y1="420" x2="900" y2="500"/>
    <line x1="900" y1="500" x2="1050" y2="500"/>
    <circle cx="1050" cy="500" r="3" fill="#E62127" stroke="none"/>
  </g>

  <!-- Status dot -->
  <circle cx="1140" cy="110" r="5" fill="#059669"/>
  <text x="1125" y="115" font-family="'JetBrains Mono', monospace" font-size="13" letter-spacing="1" fill="#4A4E57" text-anchor="end">SYSTEMS ONLINE</text>
</svg>
